{
  "name": "projectionlab-mcp",
  "version": "0.1.0",
  "description": "MCP server for reading and updating ProjectionLab plan state via the Plugin API. Drives a persistent headless Playwright session against an authenticated ProjectionLab tab.",
  "type": "module",
  "license": "MIT",
  "author": "Peter Vulgaris",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pvulgaris/projectionlab-mcp.git"
  },
  "homepage": "https://github.com/pvulgaris/projectionlab-mcp#readme",
  "bugs": "https://github.com/pvulgaris/projectionlab-mcp/issues",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "projectionlab",
    "mcp",
    "model-context-protocol",
    "claude",
    "finance",
    "fire",
    "playwright"
  ],
  "bin": {
    "pl-mcp": "dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "dev": "tsx src/cli.ts",
    "serve": "node dist/cli.js serve",
    "test": "echo 'no tests yet' && exit 1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "playwright": "^1.50.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  }
}
